{
  "expo": {
    "name": "Servis Ponuda",
    "slug": "servis-ponuda",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "servis-ponuda",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.servisponuda.app"
    },
    "android": {
      "package": "com.servisponuda.app",
      "backgroundColor": "#1a56db"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "197df789-e899-4023-99dc-3888342fbd3e"
      }
    }
  }
}
